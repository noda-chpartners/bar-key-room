---
const instagramUrl = 'https://www.instagram.com/kaginoma_ehime?igsh=NnFubWowaTUzYmxn&utm_source=qr';
---

<header class="site-header" data-header>
  <a class="site-header__brand site-link" href="#top" aria-label="Bar 鍵ノ間 ホーム">
    <img class="site-header__logo site-image" src="/assets/logo.png" alt="Bar 鍵ノ間" width="100" height="320" />
  </a>

  <button class="site-header__toggle site-button" type="button" aria-label="メニューを開く" aria-expanded="false" aria-controls="global-navigation" data-menu-toggle>
    <span class="site-header__toggle-line"></span>
    <span class="site-header__toggle-line"></span>
  </button>

  <nav class="site-header__nav" id="global-navigation" aria-label="メインナビゲーション" data-navigation>
    <a class="site-header__nav-link site-link" href="#concept"><span class="site-header__nav-number">01</span>鍵ノ間</a>
    <a class="site-header__nav-link site-link" href="#space"><span class="site-header__nav-number">02</span>空間</a>
    <a class="site-header__nav-link site-link" href="#menu"><span class="site-header__nav-number">03</span>メニュー</a>
    <a class="site-header__nav-link site-link" href="#information"><span class="site-header__nav-number">04</span>店舗情報</a>
    <a class="site-header__instagram site-link" href={instagramUrl} target="_blank" rel="noreferrer">Instagram</a>
  </nav>
</header>

<style lang="scss">
  @use "../styles/tokens" as *;
  @use "../styles/mixins" as *;

  .site-header {
    position: fixed;
    z-index: 50;
    top: 0;
    right: 0;
    left: 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 28px 36px;
    pointer-events: none;
    transition: background 0.5s ease, padding 0.5s ease;
  }

  .site-header.is-scrolled {
    padding-block: 18px;
    background: linear-gradient(180deg, rgba($color-ink, 0.9), transparent);
  }

  .site-header__brand,
  .site-header__toggle,
  .site-header__nav {
    pointer-events: auto;
  }

  .site-header__brand {
    position: relative;
    z-index: 2;
    width: 34px;
  }

  .site-header__logo {
    height: auto;
    filter: drop-shadow(0 4px 14px rgba($color-ink, 0.35));
  }

  .site-header__toggle {
    display: none;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: clamp(22px, 3vw, 48px);
    padding-top: 8px;
  }

  .site-header__nav-link,
  .site-header__instagram {
    @include interactive-line;
    color: $color-paper;
    font-family: $font-sans;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
  }

  .site-header__nav-number {
    margin-right: 8px;
    color: $color-brass-light;
    font-size: 0.58rem;
  }

  .site-header__instagram {
    color: $color-brass-light;
  }

  @include media-tablet {
    .site-header {
      padding: 22px 24px;
    }

    .site-header__brand {
      width: 28px;
    }

    .site-header__toggle {
      position: relative;
      z-index: 2;
      display: grid;
      width: 48px;
      height: 48px;
      place-content: center;
      gap: 8px;
      border: 1px solid rgba($color-brass-light, 0.4);
      border-radius: 50%;
    }

    .site-header__toggle-line {
      display: block;
      width: 18px;
      height: 1px;
      background: $color-paper;
      transition: transform 0.45s $ease-luxury;
    }

    .site-header__toggle[aria-expanded="true"] .site-header__toggle-line:first-child {
      transform: translateY(4.5px) rotate(45deg);
    }

    .site-header__toggle[aria-expanded="true"] .site-header__toggle-line:last-child {
      transform: translateY(-4.5px) rotate(-45deg);
    }

    .site-header__nav {
      position: fixed;
      inset: 0;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 24px;
      padding: 80px 12vw;
      visibility: hidden;
      background: rgba($color-ink, 0.98);
      opacity: 0;
      transition: opacity 0.45s ease, visibility 0.45s;
    }

    .site-header__nav.is-open {
      visibility: visible;
      opacity: 1;
    }

    .site-header__nav-link,
    .site-header__instagram {
      font-family: $font-serif;
      font-size: clamp(1.5rem, 6vw, 2.4rem);
      letter-spacing: 0.1em;
      transform: translateY(14px);
      transition: transform 0.5s $ease-luxury;
    }

    .site-header__nav.is-open .site-header__nav-link,
    .site-header__nav.is-open .site-header__instagram {
      transform: translateY(0);
    }
  }
</style>
