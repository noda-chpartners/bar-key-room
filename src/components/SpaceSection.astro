<section class="space" id="space" aria-labelledby="space-title">
  <div class="space__heading">
    <p class="section-kicker" data-reveal>THE SPACE / 02</p>
    <h2 class="space__title section-title" id="space-title" data-reveal>静けさと、<br />灯りの間。</h2>
    <p class="space__lead" data-reveal>植物の陰影と、木の質感。<br />夜をゆっくりと過ごすための空間です。</p>
  </div>

  <div class="space__gallery" data-gallery>
    <figure class="space__figure space__figure--main" data-parallax="-8">
      <picture class="space__picture">
        <source srcset="/assets/sp-theater.jpg" media="(max-width: 600px)" />
        <img class="space__image site-image" src="/assets/theater.png" alt="植物の天井とスクリーンがある鍵ノ間の店内" width="1672" height="941" loading="lazy" />
      </picture>
      <figcaption class="space__caption">THEATER SPACE</figcaption>
    </figure>

    <figure class="space__figure space__figure--sub" data-parallax="10">
      <img class="space__image site-image" src="/assets/tennai.png" alt="ソファー席のある鍵ノ間の店内" width="1448" height="1086" loading="lazy" />
      <figcaption class="space__caption">SOFA SPACE</figcaption>
    </figure>

    <figure class="space__figure space__figure--detail" data-parallax="-5">
      <img class="space__image site-image" src="/assets/tennai02.png" alt="鍵ノ間の店内の灯りと植物" width="1672" height="941" loading="lazy" />
      <figcaption class="space__caption">NIGHT INTERIOR</figcaption>
    </figure>
  </div>

  <div class="space__movie" data-movie-panel>
    <video class="space__video site-video" autoplay muted loop playsinline aria-hidden="true">
      <source src="/assets/sp-movie02.mp4" media="(max-width: 700px)" type="video/mp4" />
      <source src="/assets/movie02.mp4" type="video/mp4" />
    </video>
    <div class="space__movie-shade"></div>
    <p class="space__movie-copy" data-reveal>夜の鍵を、<br />ゆっくりと回す。</p>
  </div>

  <div class="space__marquee" aria-hidden="true">
    <div class="space__marquee-track">
      <span class="space__marquee-text">BAR KAGINOMA · MATSUYAMA · OPEN 21:00 — 04:00 · </span>
      <span class="space__marquee-text">BAR KAGINOMA · MATSUYAMA · OPEN 21:00 — 04:00 · </span>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/tokens" as *;
  @use "../styles/mixins" as *;

  .space {
    position: relative;
    padding-top: clamp(100px, 13vw, 210px);
    background: $color-paper;
    color: $color-ink;
  }

  .space__heading {
    @include section-shell;
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1.2fr 0.8fr;
    align-items: end;
    gap: 32px;
  }

  .space__heading .section-kicker {
    color: #806638;
    align-self: start;
    padding-top: 18px;
  }

  .space__title {
    font-size: clamp(2.8rem, 5.7vw, 6rem);
  }

  .space__lead {
    padding-bottom: 12px;
    color: #685f52;
    font-size: 0.88rem;
    letter-spacing: 0.14em;
    line-height: 2.15;
  }

  .space__gallery {
    @include section-shell;
    display: grid;
    grid-template-columns: 1.5fr 0.5fr 1fr;
    grid-template-rows: auto auto;
    gap: clamp(18px, 2.6vw, 42px);
    margin-top: clamp(72px, 10vw, 140px);
    padding-bottom: clamp(140px, 18vw, 260px);
  }

  .space__figure {
    position: relative;
    overflow: hidden;
    background: $color-ink-soft;
  }

  .space__figure--main {
    grid-column: 1 / 3;
    aspect-ratio: 1.48;
  }

  .space__figure--sub {
    grid-column: 3;
    margin-top: 25%;
    aspect-ratio: 0.72;
  }

  .space__figure--detail {
    grid-row: 2;
    grid-column: 2 / 4;
    width: 78%;
    margin-top: 2vw;
    margin-left: auto;
    aspect-ratio: 1.75;
  }

  .space__picture {
    display: block;
    height: 100%;
  }

  .space__image {
    height: 116%;
    object-fit: cover;
    transform: translateY(-8%);
    transition: filter 0.8s ease, transform 1.3s $ease-luxury;
  }

  .space__figure:hover .space__image {
    filter: brightness(1.08);
    transform: translateY(-8%) scale(1.025);
  }

  .space__caption {
    position: absolute;
    right: 16px;
    bottom: 14px;
    padding: 8px 10px;
    background: rgba($color-ink, 0.72);
    color: $color-paper;
    font-family: $font-sans;
    font-size: 0.5rem;
    letter-spacing: 0.26em;
  }

  .space__movie {
    position: relative;
    height: min(78svh, 860px);
    overflow: hidden;
    clip-path: inset(0 9% 0 9%);
    background: $color-ink;
  }

  .space__video {
    height: 100%;
    object-fit: cover;
  }

  .space__movie-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba($color-ink, 0.74), transparent 62%), linear-gradient(0deg, rgba($color-ink, 0.45), transparent 50%);
  }

  .space__movie-copy {
    position: absolute;
    top: 50%;
    left: clamp(8vw, 14vw, 220px);
    color: $color-paper;
    font-size: clamp(2.5rem, 6.4vw, 7rem);
    font-weight: 400;
    letter-spacing: 0.1em;
    line-height: 1.35;
    text-shadow: 0 12px 40px rgba($color-ink, 0.5);
    transform: translateY(-50%);
  }

  .space__marquee {
    overflow: hidden;
    padding-block: 30px;
    border-bottom: 1px solid rgba($color-ink, 0.14);
    background: $color-brass-light;
  }

  .space__marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 24s linear infinite;
  }

  .space__marquee-text {
    color: $color-ink;
    font-family: $font-sans;
    font-size: clamp(0.72rem, 1.1vw, 1rem);
    letter-spacing: 0.34em;
    white-space: nowrap;
  }

  @keyframes marquee {
    to { transform: translateX(-50%); }
  }

  @include media-tablet {
    .space__heading {
      grid-template-columns: 1fr 2fr;
    }

    .space__lead {
      grid-column: 2;
    }

    .space__gallery {
      grid-template-columns: 1fr 1fr;
    }

    .space__figure--main {
      grid-column: 1 / 3;
    }

    .space__figure--sub {
      grid-column: 1;
      margin-top: 0;
    }

    .space__figure--detail {
      grid-row: 2;
      grid-column: 2;
      width: 100%;
      margin-top: 18%;
      aspect-ratio: 0.9;
    }
  }

  @include media-mobile {
    .space__heading {
      display: block;
    }

    .space__title {
      margin-top: 22px;
    }

    .space__lead {
      margin-top: 28px;
    }

    .space__gallery {
      display: flex;
      flex-direction: column;
      margin-top: 58px;
      padding-bottom: 110px;
    }

    .space__figure--main {
      aspect-ratio: 0.72;
    }

    .space__figure--sub {
      width: 76%;
      margin-top: 20px;
      margin-left: auto;
    }

    .space__figure--detail {
      width: 88%;
      margin-top: 20px;
      margin-left: 0;
      aspect-ratio: 1.1;
    }

    .space__movie {
      height: 70svh;
      clip-path: inset(0 16px 0 16px);
    }

    .space__movie-copy {
      left: 10vw;
    }

    .space__marquee {
      padding-block: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .space__marquee-track {
      animation-play-state: paused;
    }
  }
</style>
