---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = 'Bar 鍵ノ間,かぎのま,松山 バー,二番町 バー,愛媛 バー,隠れ家バー,松山市',
  ogImage = '/assets/ogp.png',
  noindex = false,
} = Astro.props;

const site = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImageURL = new URL(ogImage, site);
const siteName = 'Bar 鍵ノ間';
const locale = 'ja_JP';
const robots = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${canonicalURL.origin}/#website`,
      url: canonicalURL.origin,
      name: siteName,
      description,
      inLanguage: 'ja',
      publisher: { '@id': `${canonicalURL.origin}/#bar` },
    },
    {
      '@type': 'BarOrPub',
      '@id': `${canonicalURL.origin}/#bar`,
      name: siteName,
      alternateName: ['かぎのま', 'Bar Kaginoma', '鍵ノ間'],
      description,
      url: canonicalURL.href,
      image: ogImageURL.href,
      priceRange: '¥¥',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '二番町1丁目5-2 古唐人星館9F西',
        addressLocality: '松山市',
        addressRegion: '愛媛県',
        addressCountry: 'JP',
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
          opens: '21:00',
          closes: '04:00',
        },
      ],
      sameAs: ['https://www.instagram.com/kaginoma_ehime/'],
      hasMap: 'https://www.google.com/maps/search/?api=1&query=%E6%84%9B%E5%AA%9B%E7%9C%8C%E6%9D%BE%E5%B1%B1%E5%B8%82%E4%BA%8C%E7%95%AA%E7%94%BA1%E4%B8%81%E7%9B%AE5-2%20%E5%8F%A4%E5%94%90%E4%BA%BA%E6%98%9F%E9%A4%A89F%E8%A5%BF',
    },
  ],
};
---

<!doctype html>
<html class="site-root" lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="author" content={siteName} />
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no, email=no, address=no" />
    <meta name="theme-color" content="#090908" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="google-site-verification" content="W6X3cwCqNwAUejsnK3WonJ1538dIruj4tj0PKa2gu5U" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:secure_url" content={ogImageURL.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={`${siteName} のロゴ`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta name="twitter:image:alt" content={`${siteName} のロゴ`} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="site-body is-loading">
    <slot />
  </body>
</html>
