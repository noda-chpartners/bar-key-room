---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import HeroSection from '../components/HeroSection.astro';
import ConceptSection from '../components/ConceptSection.astro';
import SpaceSection from '../components/SpaceSection.astro';
import MenuSection from '../components/MenuSection.astro';
import InformationSection from '../components/InformationSection.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = 'Bar 鍵ノ間（かぎのま）｜松山市二番町の隠れ家バー';
const description =
  '愛媛県松山市二番町の隠れ家バー「Bar 鍵ノ間」。植物と木のぬくもりに包まれた空間で、21:00〜04:00まで営業。日曜定休。ご予約はInstagramのDMにて。';
---

<BaseLayout title={title} description={description}>
  <SiteHeader />
  <main class="site-main">
    <HeroSection />
    <ConceptSection />
    <SpaceSection />
    <MenuSection />
    <InformationSection />
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  import '../scripts/animations.js';
</script>
